# ============================================================================
# ECOMMERCE SELLER PERFORMANCE - DEVELOPMENT ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your local development values
#
# WARNING: Never commit the .env file to version control!
# ============================================================================

# ==================== DJANGO CONFIGURATION ====================
DEBUG=True
SECRET_KEY=django-insecure-local-dev-key-bu8j(de+*&&1v1o5q=mxa@b(u8t14z6
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== DATABASE ====================
# For development, SQLite is sufficient
# In production, use PostgreSQL: postgresql://user:password@localhost:5432/ecommerce
DATABASE_URL=sqlite:///./db.sqlite3

# ==================== EMAIL CONFIGURATION ====================
# For local development, use console backend to see emails in terminal output
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For Gmail SMTP (requires App Password, not regular password):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx (from Google App Passwords)

# Local development defaults
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ecommerceseller.local

# Email Verification Settings
EMAIL_VERIFICATION_REQUIRED=False
EMAIL_VERIFICATION_TIMEOUT_HOURS=24

# ==================== CELERY CONFIGURATION ====================
# For local development without Redis, use eager execution
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_ALWAYS_EAGER=True
CELERY_TASK_EAGER_PROPAGATES=True

# For production with Redis:
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_TASK_ALWAYS_EAGER=False
# CELERY_TASK_EAGER_PROPAGATES=False

# ==================== CACHE CONFIGURATION ====================
CACHE_TIMEOUT=900  # 15 minutes

# ==================== SECURITY SETTINGS ====================
# Local development - security is relaxed
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Production settings (uncomment when deploying):
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ==================== LOGGING ====================
LOG_LEVEL=DEBUG

# ==================== API SETTINGS ====================
API_PAGINATION_SIZE=20
API_THROTTLE_RATE=1000
